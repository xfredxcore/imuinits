std::string calculate_units(const std::string& formula, const std::string& want) {
    std::string cmd = "units -t \"" + formula + "\" \"" + want + "\"";
    char buffer[128];
    std::string result = "";
    FILE* pipe = popen(cmd.c_str(), "r");
    if (!pipe) return "Error executing units";
    while (fgets(buffer, sizeof(buffer), pipe) != NULL) {
        result += buffer;
    }
    pclose(pipe);
    if (!result.empty() && result.back() == '\n') result.pop_back();
    return result.empty() ? "Dimension mismatch / Syntax Error!" : result;
}

std::vector<std::string> load_units_hints() {
    std::vector<std::string> list;
    std::ifstream file("/usr/share/units/definitions.units");
    if (!file.is_open()) {
        list.push_back("foot"); list.push_back("meter"); list.push_back("kg"); list.push_back("horsepower");
        return list;
    }
    std::string line;
    while (std::getline(file, line)) {
        if (line.empty() || line[0] == '/' || line[0] == '#' || line[0] == '!' || line[0] == '-' || line[0] == ' ' || line[0] == '\t') continue;
        std::stringstream ss(line);
        std::string unit;
        if (ss >> unit) {
            if (unit.length() <= 1 || !islower(unit[0])) continue;

            size_t end_pos = unit.find_first_of("-_!@$()[]+=0123456789");
            if (end_pos != std::string::npos) {
                unit = unit.substr(0, end_pos);
            }

            if (unit.length() > 1 && islower(unit[0])) {
                list.push_back(unit);
            }
        }
    }
    std::sort(list.begin(), list.end());
    list.erase(std::unique(list.begin(), list.end()), list.end());
    return list;
}

void ExpressionInputWithHints(const char* label, char* buf, size_t buf_size, const std::vector<std::string>& units_list) {
    ImGui::SetNextItemWidth(-1.0f);
    ImGui::InputText(label, buf, buf_size);

    std::string current_formula(buf);
    if (current_formula.empty()) return;

    size_t last_space = current_formula.find_last_of(" */()+-");
    std::string last_word = (last_space == std::string::npos) ? current_formula : current_formula.substr(last_space + 1);

    if (last_word.empty()) return;

    std::string last_word_lower = last_word;
    std::transform(last_word_lower.begin(), last_word_lower.end(), last_word_lower.begin(), ::tolower);

    std::vector<std::string> matches;
    for (const auto& unit : units_list) {
        if (unit.rfind(last_word_lower, 0) == 0) {
            matches.push_back(unit);
        }
        if (matches.size() >= 5) break;
    }

    if (!matches.empty()) {
        ImGui::PushStyleColor(ImGuiCol_ChildBg, ImVec4(0.12f, 0.12f, 0.16f, 0.95f));
        std::string child_id = "##hints_child_" + std::string(label);

        if (ImGui::BeginChild(child_id.c_str(), ImVec2(-1, matches.size() * 24.0f + 4.0f), ImGuiChildFlags_Borders)) {
            for (const auto& match : matches) {
                if (ImGui::Selectable(match.c_str(), false)) {
                    std::string prefix = (last_space == std::string::npos) ? "" : current_formula.substr(0, last_space + 1);
                    std::string new_formula = prefix + match;
                    snprintf(buf, buf_size, "%s", new_formula.c_str());
                }
            }
            ImGui::EndChild();
        }
        ImGui::PopStyleColor();
    }
}

int main() {
    if (!glfwInit()) return 1;
    glfwWindowHint(GLFW_RESIZABLE, GLFW_FALSE);
    GLFWwindow* window = glfwCreateWindow(500, 480, "imuinits", NULL, NULL);
    if (!window) return 1;
    glfwMakeContextCurrent(window);
    glfwSwapInterval(1);

    IMGUI_CHECKVERSION();
    ImGui::CreateContext();
    ImGuiIO& io = ImGui::GetIO(); (void)io;

    ImGuiStyle& style = ImGui::GetStyle();
    style.WindowRounding = 8.0f;
    style.FrameRounding = 4.0f;
    style.PopupRounding = 4.0f;
    style.ScrollbarRounding = 4.0f;
    style.WindowBorderSize = 1.0f;
    style.FrameBorderSize = 1.0f;
    style.Colors[ImGuiCol_WindowBg] = ImVec4(0.09f, 0.09f, 0.11f, 1.00f);
    style.Colors[ImGuiCol_Border] = ImVec4(0.22f, 0.22f, 0.26f, 1.00f);
    style.Colors[ImGuiCol_FrameBg] = ImVec4(0.15f, 0.15f, 0.19f, 1.00f);
    style.Colors[ImGuiCol_FrameBgHovered] = ImVec4(0.21f, 0.21f, 0.27f, 1.00f);
    style.Colors[ImGuiCol_FrameBgActive] = ImVec4(0.17f, 0.17f, 0.23f, 1.00f);

    // Юзаем дефолтный встроенный шрифт без всякого внешнего говна
    ImFontConfig config;
    config.SizePixels = 16.0f;
    io.Fonts->AddFontDefault(&config);

    ImGui_ImplGlfw_InitForOpenGL(window, true);
    ImGui_ImplOpenGL3_Init("#version 130");

    std::vector<std::string> units_list = load_units_hints();

    static char formula_buf[256] = "10 btu / 2 foot * 30 activehorsepower";
    static char target_buf[64] = "watt";
    std::string result_text = "";

    while (!glfwWindowShouldClose(window)) {
        glfwPollEvents();
        ImGui_ImplOpenGL3_NewFrame();
        ImGui_ImplGlfw_NewFrame();
        ImGui::NewFrame();

        ImGui::SetNextWindowPos(ImVec2(0, 0));
        ImGui::SetNextWindowSize(io.DisplaySize);
        ImGui::Begin("imuinits", NULL, ImGuiWindowFlags_NoCollapse | ImGuiWindowFlags_NoResize | ImGuiWindowFlags_NoMove);

        ImGui::Text("Enter Complex Formula:");
        ExpressionInputWithHints("##formula_input", formula_buf, IM_ARRAYSIZE(formula_buf), units_list);

        ImGui::Spacing();

        ImGui::Text("Target Unit:");
        ExpressionInputWithHints("##target_input", target_buf, IM_ARRAYSIZE(target_buf), units_list);

        ImGui::Spacing();
        ImGui::Separator();
        ImGui::Spacing();

        float time = (float)glfwGetTime();
        float pulse = (sinf(time * 4.0f) + 1.0f) * 0.5f;
        ImVec4 btn_color = ImVec4(0.2f + pulse * 0.05f, 0.4f + pulse * 0.08f, 0.7f + pulse * 0.05f, 1.0f);
        ImVec4 btn_hover = ImVec4(0.3f + pulse * 0.05f, 0.5f + pulse * 0.08f, 0.8f + pulse * 0.05f, 1.0f);
        ImGui::PushStyleColor(ImGuiCol_Button, btn_color);
        ImGui::PushStyleColor(ImGuiCol_ButtonHovered, btn_hover);

        if (ImGui::Button("EVALUATE & CONVERT", ImVec2(-1, 40))) {
            result_text = calculate_units(std::string(formula_buf), std::string(target_buf));
        }
        ImGui::PopStyleColor(2);

        ImGui::Spacing();
        ImGui::Text("RESULT:");

        ImGui::PushStyleColor(ImGuiCol_ChildBg, ImVec4(0.12f, 0.12f, 0.15f, 1.0f));
        if (ImGui::BeginChild("##result_frame", ImVec2(-1, 80), ImGuiChildFlags_Borders, ImGuiWindowFlags_HorizontalScrollbar)) {
            ImGui::TextColored(ImVec4(0.0f, 1.0f, 0.0f, 1.0f), "%s", result_text.c_str());
            ImGui::EndChild();
        }
        ImGui::PopStyleColor();

        ImGui::Spacing();
        ImGui::Separator();

        std::string author_text = "ImUInits (based on Units & ImGUI)\nxfredxcore";
        float text_width = ImGui::CalcTextSize(author_text.c_str()).x;
        ImGui::SetCursorPosX(ImGui::GetWindowWidth() - text_width - 15);
        ImGui::TextDisabled("%s", author_text.c_str());

        ImGui::End();

        ImGui::Render();
        int display_w, display_h;
        glfwGetFramebufferSize(window, &display_w, &display_h);
        glViewport(0, 0, display_w, display_h);
        glClearColor(0.1f, 0.1f, 0.1f, 1.0f);
        glClear(GL_COLOR_BUFFER_BIT);
        ImGui_ImplOpenGL3_RenderDrawData(ImGui::GetDrawData());
        glfwSwapBuffers(window);
    }

    ImGui_ImplOpenGL3_Shutdown();
    ImGui_ImplGlfw_Shutdown();
    ImGui::DestroyContext();
    glfwDestroyWindow(window);
    glfwTerminate();

    return 0;
}